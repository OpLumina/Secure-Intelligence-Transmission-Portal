# ==========================================
# Hardened Environment Configuration
# ==========================================

# 1. ENCRYPTION SECRETS (SRG-APP-000231)
# PGP_PASSPHRASE_FILE points to the Docker Secret mount point
PGP_PASSPHRASE_FILE=/run/secrets/pgp_passphrase

# 2. AUTHENTICATION (JWT)
# JWT_SECRET_FILE points to the Docker Secret mount point
JWT_SECRET_FILE=/run/secrets/jwt_secret

# 3. BACKEND PATHS
# Exact paths within the container volume mounts
PGP_KEY_PATH=/app/pgp/priv/dirtmap_private.asc
PGP_PUB_KEY_PATH=/app/pgp/pub/dirtmap_public.asc
REPORT_STORAGE_PATH=/app/db/reports
USER_DB_PATH=/app/db/users.db

# 4. SERVER SETTINGS
NODE_ENV=production
PORT=3000

# 5. LOGGING (V-222390)
# 'info' provides sufficient auditing for STIG compliance
LOG_LEVEL=info
